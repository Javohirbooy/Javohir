# ========== Neon PostgreSQL (majburiy production) ==========
# Pooled — Vercel / serverless (Neon "Pooled connection" + pgbouncer=true)
DATABASE_URL="postgresql://USER:PASSWORD@ep-PROJECT-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct — prisma migrate / db push (poolersiz hostname)
DIRECT_URL="postgresql://USER:PASSWORD@ep-PROJECT.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# ========== NextAuth / Auth.js v5 ==========
# Kamida 32 belgi, tasodifiy (productionda majburiy)
AUTH_SECRET="o‘zgartiring-uzun-maxfiy-kalit-kamida-32-belgi"

# Production: to‘liq HTTPS URL (masalan https://your-app.vercel.app)
# Vercel avtomatik: AUTH_URL yoki NEXTAUTH_URL — ikkalasi qabul qilinadi
NEXTAUTH_URL="http://localhost:3000"
# AUTH_URL="https://your-app.vercel.app"

# ========== Ixtiyoriy ==========
# Vercelda odatda avtomatik; qo‘lda faqat kerak bo‘lsa
# VERCEL_URL="your-app.vercel.app"

